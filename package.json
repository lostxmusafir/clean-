{
  "name": "drc-tournaments",
  "version": "1.0.0",
  "description": "Sports management dashboard with live scores, tournaments, and player tracking",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.drctournaments.app",
    "productName": "DRC Tournaments",
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": ["sports", "live-scores", "tournaments", "electron", "dashboard"],
  "author": "Neon Observatory",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}
